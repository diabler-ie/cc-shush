#!/usr/bin/env bash
# claude-shush: patch Claude Code's harness reminders that don't carry their
# weight — silence the "task tools haven't been used recently" nudge and
# soften the all-caps "IMPORTANT: ... you MUST ..." stack on the user-typed-
# mid-tool reminder.
#
# Idempotent. Backs up before patching. macOS re-signs ad-hoc; first launch
# may prompt for Keychain access (click "Always Allow") depending on your
# Keychain ACL.

set -euo pipefail

usage() {
  cat <<'EOF'
usage: claude-shush [-n] [path-to-claude-binary]

Patches Claude Code's compiled binary to:
  1. Blank the "task tools haven't been used recently..." system reminder
     so it stops nagging on short tasks.
  2. Soften the "IMPORTANT: ... you MUST address the user's message ...
     Do not ignore it." reminder that fires when the user types while
     a tool is running — same information, neutral tone.

If no path is given, resolves `which claude` and follows symlinks.

  -n   dry run: report what would change, modify nothing
  -h   show this help

After patching, the binary is re-signed ad-hoc on macOS. If your Keychain
ACL is strict, the first launch will prompt for access; click "Always
Allow" to remember the new signature for that binary version.

The patch is per-binary. Each Claude Code update installs a new binary;
rerun this script on the new file after each update.
EOF
}

DRY=0
while getopts "nh" opt; do
  case "$opt" in
    n) DRY=1 ;;
    h) usage; exit 0 ;;
    *) usage; exit 2 ;;
  esac
done
shift $((OPTIND-1))

if [[ $# -ge 1 ]]; then
  TARGET="$1"
else
  if ! command -v claude >/dev/null 2>&1; then
    echo "error: 'claude' not on PATH; pass a path argument" >&2
    exit 1
  fi
  TARGET="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$(command -v claude)")"
fi

if [[ ! -f "$TARGET" ]]; then
  echo "error: $TARGET is not a regular file" >&2
  exit 1
fi

echo "target: $TARGET"

DRY="$DRY" python3 - "$TARGET" <<'PYEOF'
import os, shutil, sys, time

target = sys.argv[1]
dry = os.environ.get("DRY", "0") == "1"

PATCHES = [
    {
        "name": "task-tools reminder (blank content)",
        "mode": "blank-span",
        "start": b"The task tools haven't been used recently.",
        "end": b"ignore if not applicable.",
        "window": 2000,
    },
    {
        "name": "user-typed-mid-tool reminder (soften tone)",
        "mode": "replace-literal",
        "literal": (
            b"IMPORTANT: After completing your current task, you MUST address "
            b"the user's message above. Do not ignore it."
        ),
        "replacement": b"Address the user's new message above after your current task completes.",
    },
]

with open(target, "rb") as f:
    data = f.read()

regions = []  # list of (start, stop, new_bytes, patch_name) for application

for patch in PATCHES:
    name = patch["name"]
    if patch["mode"] == "blank-span":
        start_anchor = patch["start"]
        end_anchor = patch["end"]
        window = patch["window"]
        cursor = 0
        found = 0
        while True:
            idx = data.find(start_anchor, cursor)
            if idx < 0:
                break
            end_idx = data.find(end_anchor, idx, idx + window)
            if end_idx >= 0:
                stop = end_idx + len(end_anchor)
                regions.append((idx, stop, b" " * (stop - idx), name))
                cursor = stop
                found += 1
            else:
                cursor = idx + len(start_anchor)
        print(f"[{name}] found {found} occurrence(s)")
    elif patch["mode"] == "replace-literal":
        literal = patch["literal"]
        replacement = patch["replacement"]
        if len(replacement) > len(literal):
            print(f"[{name}] ERROR: replacement longer than literal "
                  f"({len(replacement)} > {len(literal)})")
            sys.exit(1)
        padded = replacement + b" " * (len(literal) - len(replacement))
        cursor = 0
        found = 0
        while True:
            idx = data.find(literal, cursor)
            if idx < 0:
                break
            regions.append((idx, idx + len(literal), padded, name))
            cursor = idx + len(literal)
            found += 1
        print(f"[{name}] found {found} occurrence(s)")
    else:
        print(f"[{name}] ERROR: unknown mode {patch['mode']!r}")
        sys.exit(1)

if not regions:
    print("nothing to patch — already patched or unknown version.")
    sys.exit(0)

print(f"\n{len(regions)} region(s) will be patched:")
for start, stop, _, name in regions:
    print(f"  {start}..{stop} ({stop-start} bytes) [{name}]")

if dry:
    print("\ndry run — not modifying.")
    sys.exit(0)

ts = time.strftime("%Y%m%dT%H%M%S")
backup = f"{target}.bak.{ts}"
shutil.copy2(target, backup)
print(f"\nbackup: {backup}")

new_data = bytearray(data)
for start, stop, new_bytes, _ in regions:
    new_data[start:stop] = new_bytes

mode = os.stat(target).st_mode
with open(target, "wb") as f:
    f.write(new_data)
os.chmod(target, mode)
print(f"patched {len(regions)} region(s) in-place.")
PYEOF

if [[ "$DRY" == "1" ]]; then
  exit 0
fi

if [[ "$(uname)" == "Darwin" ]]; then
  echo "re-signing ad-hoc (macOS)..."
  codesign --force --sign - "$TARGET"
  codesign -dvv "$TARGET" 2>&1 | grep -E "(Identifier|Authority|Signature size)" || true
  echo
  echo "  ! if macOS prompts for Keychain access on first launch,"
  echo "  ! click 'Always Allow' to remember the new signature."
fi

echo "done."
