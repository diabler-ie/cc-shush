#!/usr/bin/env bash
# claude-shush: silence Claude Code's "task tools haven't been used" reminder
# by blanking the string inside the compiled binary and re-signing ad-hoc.
#
# Idempotent. Backs up before patching. macOS re-signs ad-hoc; first launch
# will prompt for Keychain access (click "Always Allow").

set -euo pipefail

usage() {
  cat <<'EOF'
usage: claude-shush [-n] [path-to-claude-binary]

Blanks the "task tools haven't been used recently..." system reminder
inside the Claude Code binary so it stops nagging on short tasks.

If no path is given, resolves `which claude` and follows symlinks.

  -n   dry run: report what would change, modify nothing
  -h   show this help

After patching, the binary is re-signed ad-hoc on macOS. The first launch
will prompt for Keychain access — click "Always Allow" to remember the
new signature for that binary version.

The patch is per-binary. Each Claude Code update installs a new binary;
rerun this script on the new file after each update.
EOF
}

DRY=0
while getopts "nh" opt; do
  case "$opt" in
    n) DRY=1 ;;
    h) usage; exit 0 ;;
    *) usage; exit 2 ;;
  esac
done
shift $((OPTIND-1))

if [[ $# -ge 1 ]]; then
  TARGET="$1"
else
  if ! command -v claude >/dev/null 2>&1; then
    echo "error: 'claude' not on PATH; pass a path argument" >&2
    exit 1
  fi
  # macOS readlink lacks -f; use python to resolve symlinks portably
  TARGET="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$(command -v claude)")"
fi

if [[ ! -f "$TARGET" ]]; then
  echo "error: $TARGET is not a regular file" >&2
  exit 1
fi

echo "target: $TARGET"

DRY="$DRY" python3 - "$TARGET" <<'PYEOF'
import os, shutil, sys, time

target = sys.argv[1]
dry = os.environ.get("DRY", "0") == "1"

START = b"The task tools haven't been used recently."
END_PHRASE = b"ignore if not applicable."
WINDOW = 2000

with open(target, "rb") as f:
    data = f.read()

matches = []
cursor = 0
while True:
    idx = data.find(START, cursor)
    if idx < 0:
        break
    end_idx = data.find(END_PHRASE, idx, idx + WINDOW)
    if end_idx >= 0:
        stop = end_idx + len(END_PHRASE)
        matches.append((idx, stop))
        cursor = stop
    else:
        # START appears but no END nearby — likely a separate reference, skip.
        cursor = idx + len(START)

if not matches:
    print("no live reminder template found — already patched or unknown version.")
    sys.exit(0)

print(f"found {len(matches)} reminder template(s):")
for start, stop in matches:
    print(f"  bytes {start}..{stop} ({stop-start} bytes)")

if dry:
    print("dry run — not modifying.")
    sys.exit(0)

ts = time.strftime("%Y%m%dT%H%M%S")
backup = f"{target}.bak.{ts}"
shutil.copy2(target, backup)
print(f"backup: {backup}")

new_data = bytearray(data)
for start, stop in matches:
    new_data[start:stop] = b" " * (stop - start)

mode = os.stat(target).st_mode
with open(target, "wb") as f:
    f.write(new_data)
os.chmod(target, mode)
print(f"patched {len(matches)} location(s) in-place.")
PYEOF

if [[ "$DRY" == "1" ]]; then
  exit 0
fi

if [[ "$(uname)" == "Darwin" ]]; then
  echo "re-signing ad-hoc (macOS)..."
  codesign --force --sign - "$TARGET"
  codesign -dvv "$TARGET" 2>&1 | grep -E "(Identifier|Authority|Signature size)" || true
  echo
  echo "  ! first launch will prompt for Keychain access."
  echo "  ! click 'Always Allow' to remember the new signature."
fi

echo "done."
